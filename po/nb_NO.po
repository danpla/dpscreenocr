msgstr "Trykk {hotkey} for å fullføre utvalg"

#: src/ui/qt/update_checker.cpp
msgid "An error occurred while checking for updates"
msgstr "En feil oppstod under oppdateringssjekk"

#: src/ui/qt/update_checker.cpp
