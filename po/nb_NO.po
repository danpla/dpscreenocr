msgid ""
"The latest version is {latest_version}, but your system does not meet the "
"following minimum requirements: {requirements}."
msgstr ""
"Den siste versjonen er {latest_version}, men systemet ditt oppfyller ikke "
"følgende minimumskrav: {requirements}."

