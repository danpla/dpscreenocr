msgstr "Fermer dans la zone de notification"

#: src/ui/qt/main_window.cpp
msgid ""
"Closing the window will hide {app_name}. Use the notification area icon to "
"show it again."
msgstr ""
"Fermer la fenêtre masquera {app_name}. Utilisez l'icône de la zone de "
"notification pour l'afficher à nouveau."

