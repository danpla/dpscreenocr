#: src/ui/qt/main_window.cpp
msgid "Close to notification area"
msgstr "Cerrar el área de notificación"

#: src/ui/qt/main_window.cpp
msgid ""
"Closing the window will hide {app_name}. Use the notification area icon to "
"show it again."
msgstr ""
"Al cerrar la ventana se ocultará {app_name}. Utilice el icono del área de "
"notificación para volver a mostrarla."

