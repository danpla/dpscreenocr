#: src/ui/qt/main_window.cpp
msgid "Check for updates automatically"
msgstr "Comprobar actualizaciones automáticamente"

#: src/ui/qt/main_window.cpp
msgid "Run at system logon"
msgstr "Ejecutar al iniciar sesión en el sistema"

#: src/ui/qt/main_window.cpp
msgid ""
"{app_name} will start automatically when you log on to the system. The "
"program will be hidden to the notification area if the notification area "
"icon is enabled, or minimized if the icon is disabled."
msgstr ""
"{app_name} se iniciará automáticamente cuando inicies sesión en el sistema. "
"El programa se ocultará en el área de notificación si el icono del área de "
"notificación está activado, o se minimizará si el icono está desactivado."

#: src/ui/qt/main_window.cpp
msgid ""
"{app_name} will automatically check for updates at startup, but no more "
"often than once every {count} day"
msgid_plural ""
"{app_name} will automatically check for updates at startup, but no more "
"often than once every {count} days"
msgstr[0] ""
"{app_name} automáticamente comprobará actualizaciones al arranque, pero no "
"más a menudo que una vez cada {count} día"
msgstr[1] ""
"{app_name} automáticamente comprobará actualizaciones al arranque, pero no "
"más a menudo que una vez cada {count} días"

