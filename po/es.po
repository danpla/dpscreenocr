msgstr "Seleccione idiomas"

#: src/ui/qt/main_window.cpp
msgid "Please select actions"
msgstr "Seleccione acciones"

#: src/ui/qt/main_window.cpp
msgid "Press {hotkey} to start area selection"
msgstr "Pulse {hotkey} para iniciar la selección de área"

#: src/ui/qt/main_window.cpp
